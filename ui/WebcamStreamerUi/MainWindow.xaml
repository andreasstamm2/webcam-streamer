<Window x:Class="WebcamStreamerUi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WebcamStreamerUi"
        Title="Webcam Streamer"
        Height="600" Width="1240"
        Background="#F5F7FA" Foreground="#1F2937"
        FontFamily="Segoe UI" FontSize="13"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- Substitutes the static Resolutions.All list when the per-cam
             AvailableResolutions is empty (supervisor hasn't enumerated
             formats yet, or running against an older supervisor that
             doesn't emit advertised_formats). -->
        <local:ResolutionFallbackConverter x:Key="ResolutionFallback"/>

        <!-- Color tokens -->
        <SolidColorBrush x:Key="bgPanel"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="bgChrome"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="bgStatus"     Color="#F3F4F6"/>
        <SolidColorBrush x:Key="bgRowAlt"     Color="#FAFBFC"/>
        <SolidColorBrush x:Key="bgRowHover"   Color="#F1F5F9"/>
        <SolidColorBrush x:Key="bgRowSel"     Color="#DBEAFE"/>
        <SolidColorBrush x:Key="border"       Color="#E5E7EB"/>
        <SolidColorBrush x:Key="textPrimary"  Color="#1F2937"/>
        <SolidColorBrush x:Key="textMuted"    Color="#6B7280"/>
        <SolidColorBrush x:Key="textHeader"   Color="#4B5563"/>
        <SolidColorBrush x:Key="accent"       Color="#1D4ED8"/>
        <SolidColorBrush x:Key="ok"           Color="#10B981"/>
        <SolidColorBrush x:Key="warn"         Color="#F59E0B"/>
        <SolidColorBrush x:Key="off"          Color="#9CA3AF"/>
        <SolidColorBrush x:Key="err"          Color="#EF4444"/>

        <!-- Light, minimal button -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin"  Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="68"/>
            <Setter Property="Background" Value="{StaticResource bgPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource textPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#F9FAFB"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox: clean & legible -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource bgPanel}"/>
            <Setter Property="Foreground" Value="{StaticResource textPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Top bar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource bgChrome}"
                BorderBrush="{StaticResource border}" BorderThickness="0,0,0,1"
                Padding="14,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Webcam Streamer"
                               FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0"/>
                    <Button Content="About"               Click="About_Click"/>
                </StackPanel>
                <TextBlock VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource textMuted}"
                           FontFamily="Consolas, Cascadia Mono, monospace" FontSize="12"
                           Text="LAN URL pattern:  rtsp://viewer:viewer@&lt;sender-pc&gt;:8554/&lt;path&gt;"/>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource bgStatus}"
                BorderBrush="{StaticResource border}" BorderThickness="0,1,0,0"
                Padding="14,7">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ConnectionStatus}" Foreground="{StaticResource textPrimary}"/>
                <TextBlock Text=" • " Margin="10,0" Foreground="{StaticResource textMuted}"/>
                <TextBlock Text="{Binding MediaMtxStatus}"   Foreground="{StaticResource textPrimary}"/>
            </StackPanel>
        </Border>

        <!-- Camera grid -->
        <DataGrid x:Name="CamGrid"
                  ItemsSource="{Binding Cameras}"
                  AutoGenerateColumns="False"
                  Background="{StaticResource bgPanel}"
                  Foreground="{StaticResource textPrimary}"
                  RowBackground="{StaticResource bgPanel}"
                  AlternatingRowBackground="{StaticResource bgRowAlt}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource border}"
                  BorderBrush="{StaticResource border}" BorderThickness="0"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  CanUserResizeRows="False" CanUserReorderColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  RowHeight="46"
                  ColumnHeaderHeight="34"
                  SelectionUnit="FullRow"
                  Margin="0">
            <DataGrid.Resources>
                <!-- Header style -->
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"     Value="#F9FAFB"/>
                    <Setter Property="Foreground"     Value="{StaticResource textHeader}"/>
                    <Setter Property="FontWeight"     Value="SemiBold"/>
                    <Setter Property="FontSize"       Value="12"/>
                    <Setter Property="BorderBrush"    Value="{StaticResource border}"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding"        Value="12,8"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </Style>

                <!-- Cell -->
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding"         Value="12,4"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource bgRowSel}"/>
                            <Setter Property="Foreground" Value="{StaticResource textPrimary}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Row -->
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource bgRowHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource bgRowSel}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- Camera friendly name -->
                <DataGridTextColumn Header="Camera" Binding="{Binding Name}" Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- RTSP path -->
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="92">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
                            <Setter Property="Foreground" Value="{StaticResource accent}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Mode dropdown - wide enough for the longest mode name -->
                <DataGridTemplateColumn Header="Mode" Width="245">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{x:Static local:Modes.All}"
                                      SelectedItem="{Binding Mode, Mode=OneWay}"
                                      SelectionChanged="ModeCombo_SelectionChanged"
                                      Tag="{Binding}"
                                      Margin="6,6"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Resolution dropdown. Bound to the per-cam
                     AvailableResolutions (derived from the supervisor's
                     `ffmpeg -list_options` enumeration filtered by the
                     currently-selected Mode), so the user only sees
                     resolutions the cam actually advertises and ffmpeg
                     will accept. If we don't yet have advertised formats
                     (supervisor still enumerating, or older supervisor),
                     ResolutionFallbackConverter substitutes the static
                     Resolutions.All list. -->
                <DataGridTemplateColumn Header="Resolution" Width="115">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding AvailableResolutions, Converter={StaticResource ResolutionFallback}}"
                                      SelectedItem="{Binding Resolution, Mode=OneWay}"
                                      SelectionChanged="ResolutionCombo_SelectionChanged"
                                      Tag="{Binding}"
                                      Margin="6,6"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Status pill: single authoritative state model
                     (matches CameraInfo properties, also drives the tray
                     menu/tooltip): UNPLUGGED, DISABLED, STARTING, ENABLED,
                     STREAMING. The leading dot on STREAMING is the visual
                     cue that a viewer is actually attached right now. -->
                <DataGridTemplateColumn Header="Status" Width="135">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="8,2"
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- Default = UNPLUGGED grey -->
                                        <Setter Property="Background" Value="#F3F4F6"/>
                                        <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <!-- DISABLED: present && !enabled -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Present}" Value="True"/>
                                                    <Condition Binding="{Binding Enabled}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background"  Value="#E5E7EB"/>
                                                <Setter Property="BorderBrush" Value="#9CA3AF"/>
                                            </MultiDataTrigger>
                                            <!-- STARTING: present && enabled && !running -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Present}" Value="True"/>
                                                    <Condition Binding="{Binding Enabled}" Value="True"/>
                                                    <Condition Binding="{Binding Running}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background"  Value="#FEF3C7"/>
                                                <Setter Property="BorderBrush" Value="#F59E0B"/>
                                            </MultiDataTrigger>
                                            <!-- ENABLED: present && enabled && running && no viewers -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Present}" Value="True"/>
                                                    <Condition Binding="{Binding Enabled}" Value="True"/>
                                                    <Condition Binding="{Binding Running}" Value="True"/>
                                                    <Condition Binding="{Binding HasViewers}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background"  Value="#D1FAE5"/>
                                                <Setter Property="BorderBrush" Value="#10B981"/>
                                            </MultiDataTrigger>
                                            <!-- STREAMING: viewer attached -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Present}" Value="True"/>
                                                    <Condition Binding="{Binding Enabled}" Value="True"/>
                                                    <Condition Binding="{Binding Running}" Value="True"/>
                                                    <Condition Binding="{Binding HasViewers}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background"  Value="#DBEAFE"/>
                                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="UNPLUGGED"/>
                                            <Setter Property="Foreground" Value="#6B7280"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Present}" Value="True"/>
                                                        <Condition Binding="{Binding Enabled}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Text"       Value="DISABLED"/>
                                                    <Setter Property="Foreground" Value="#4B5563"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Present}" Value="True"/>
                                                        <Condition Binding="{Binding Enabled}" Value="True"/>
                                                        <Condition Binding="{Binding Running}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Text"       Value="STARTING"/>
                                                    <Setter Property="Foreground" Value="#92400E"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Present}" Value="True"/>
                                                        <Condition Binding="{Binding Enabled}" Value="True"/>
                                                        <Condition Binding="{Binding Running}" Value="True"/>
                                                        <Condition Binding="{Binding HasViewers}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Text"       Value="ENABLED"/>
                                                    <Setter Property="Foreground" Value="#047857"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Present}" Value="True"/>
                                                        <Condition Binding="{Binding Enabled}" Value="True"/>
                                                        <Condition Binding="{Binding Running}" Value="True"/>
                                                        <Condition Binding="{Binding HasViewers}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Text"       Value="● STREAMING"/>
                                                    <Setter Property="Foreground" Value="#1D4ED8"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- PID -->
                <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="64">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
                            <Setter Property="Foreground" Value="{StaticResource textMuted}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Restarts (right-aligned) -->
                <DataGridTextColumn Header="Restarts" Binding="{Binding Restarts}" Width="68">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
                            <Setter Property="Foreground" Value="{StaticResource textMuted}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,12,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Full RTSP URL (selectable + one-click copy) -->
                <DataGridTemplateColumn Header="RTSP URL" Width="*" MinWidth="280">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Content="Copy"
                                        Click="CopyUrl_Click"
                                        Tag="{Binding}"
                                        MinWidth="56"
                                        Margin="6,0,0,0"
                                        ToolTip="Copy this RTSP URL to the clipboard"/>
                                <TextBox Text="{Binding FullUrl, Mode=OneWay}"
                                         IsReadOnly="True" BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{StaticResource accent}"
                                         FontFamily="Consolas, Cascadia Mono, monospace"
                                         FontSize="12"
                                         VerticalAlignment="Center"
                                         ToolTip="Click to select; Ctrl+C to copy"/>
                            </DockPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Per-row actions. The activate/deactivate button binds
                     to set-stream-enabled; its label flips based on the
                     Enabled flag so a single button covers both directions.
                     Restart is only meaningful for enabled cams; disabled
                     ones have no publisher to restart. -->
                <DataGridTemplateColumn Header="" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Click="EnableToggle_Click" Tag="{Binding}" MinWidth="92">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Content" Value="Deactivate"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                    <Setter Property="Content" Value="Activate"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Restart" Click="Restart_Click" Tag="{Binding}"
                                        IsEnabled="{Binding Enabled}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
