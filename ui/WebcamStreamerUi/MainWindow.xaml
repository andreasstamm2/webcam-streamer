<Window x:Class="WebcamStreamerUi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WebcamStreamerUi"
        Title="Webcam Streamer"
        Height="600" Width="1240"
        Background="#F5F7FA" Foreground="#1F2937"
        FontFamily="Segoe UI" FontSize="13"
        UseLayoutRounding="True"
        Icon="/app.ico">

    <Window.Resources>
        <!-- Substitutes the static Resolutions.All list when the per-cam
             AvailableResolutions is empty (supervisor hasn't enumerated
             formats yet, or running against an older supervisor that
             doesn't emit advertised_formats). -->
        <local:ResolutionFallbackConverter x:Key="ResolutionFallback"/>

        <!-- Color tokens -->
        <SolidColorBrush x:Key="bgPanel"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="bgChrome"     Color="#FFFFFF"/>
        <SolidColorBrush x:Key="bgStatus"     Color="#F3F4F6"/>
        <SolidColorBrush x:Key="bgRowAlt"     Color="#FAFBFC"/>
        <SolidColorBrush x:Key="bgRowHover"   Color="#F1F5F9"/>
        <SolidColorBrush x:Key="bgRowSel"     Color="#DBEAFE"/>
        <SolidColorBrush x:Key="border"       Color="#E5E7EB"/>
        <SolidColorBrush x:Key="textPrimary"  Color="#1F2937"/>
        <SolidColorBrush x:Key="textMuted"    Color="#6B7280"/>
        <SolidColorBrush x:Key="textHeader"   Color="#4B5563"/>
        <SolidColorBrush x:Key="accent"       Color="#1D4ED8"/>
        <SolidColorBrush x:Key="ok"           Color="#10B981"/>
        <SolidColorBrush x:Key="warn"         Color="#F59E0B"/>
        <SolidColorBrush x:Key="off"          Color="#9CA3AF"/>
        <SolidColorBrush x:Key="err"          Color="#EF4444"/>

        <!-- Light, minimal button -->
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin"  Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="68"/>
            <Setter Property="Background" Value="{StaticResource bgPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource textPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#F9FAFB"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox: clean & legible -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource bgPanel}"/>
            <Setter Property="Foreground" Value="{StaticResource textPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Top bar. About moved to the tray menu so it's not duplicated;
             LAN URL pattern text removed (each row already shows the
             real URL with a Copy button). -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource bgChrome}"
                BorderBrush="{StaticResource border}" BorderThickness="0,0,0,1"
                Padding="14,10">
            <TextBlock Text="Webcam Streamer"
                       FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Settings panel above the camera grid. Currently hosts a Security
             section (viewer credentials); Phase 3 will add a second
             collapsible section for notifications / autostart / default-
             enabled. The Security section is open by default so a fresh
             user immediately sees the generated password they need to give
             to LAN viewers. -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource bgPanel}"
                BorderBrush="{StaticResource border}" BorderThickness="0,0,0,1"
                Padding="14,10">
            <StackPanel>
                <Expander Header="Security" IsExpanded="True">
                    <Grid Margin="0,10,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Username:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox   Grid.Column="1" x:Name="SecUserBox"
                                   Text="{Binding ViewerUser, UpdateSourceTrigger=PropertyChanged}"
                                   Padding="6,4" VerticalContentAlignment="Center"
                                   FontFamily="Consolas, Cascadia Mono, monospace" FontSize="13"/>
                        <TextBlock Grid.Column="3" Text="Password:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <local:RevealingPasswordBox Grid.Column="4" x:Name="SecPassBox"
                                                    Password="{Binding ViewerPassword, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                        <Button Grid.Column="6" Content="Apply"
                                Click="ApplyCredentials_Click"
                                MinWidth="80"
                                VerticalAlignment="Center"
                                ToolTip="Apply new credentials. Connected viewers will be disconnected and must re-auth."/>
                    </Grid>
                </Expander>

                <!-- Settings section. Mirrors the (now-retired) standalone
                     SettingsWindow dialog. Each checkbox live-applies on
                     change; no Save button. Settings_Changed_Inline both
                     persists settings.json and (for autostart) writes the
                     HKCU\...\Run entry. Collapsed by default to keep the
                     window compact; Security is the daily-use surface. -->
                <Expander Header="Settings" IsExpanded="False" Margin="0,10,0,0">
                    <StackPanel Margin="0,10,0,4">
                        <CheckBox x:Name="OptNotifications"
                                  Margin="0,0,0,8"
                                  Checked="Settings_Changed_Inline"
                                  Unchecked="Settings_Changed_Inline">
                            <CheckBox.Content>
                                <StackPanel>
                                    <TextBlock Text="Show notifications" FontSize="14"/>
                                    <TextBlock Text="Pop a tray toast when a viewer connects, or when an authentication attempt fails."
                                               Foreground="{StaticResource textMuted}" FontSize="12" TextWrapping="Wrap"
                                               Margin="0,2,0,0" MaxWidth="540"/>
                                </StackPanel>
                            </CheckBox.Content>
                        </CheckBox>
                        <CheckBox x:Name="OptAutostart"
                                  Margin="0,0,0,8"
                                  Checked="Settings_Changed_Inline"
                                  Unchecked="Settings_Changed_Inline">
                            <CheckBox.Content>
                                <StackPanel>
                                    <TextBlock Text="Start automatically when I log in" FontSize="14"/>
                                    <TextBlock Text="Adds a per-user registry entry (HKCU\...\Run). Streaming starts shortly after you sign in to Windows."
                                               Foreground="{StaticResource textMuted}" FontSize="12" TextWrapping="Wrap"
                                               Margin="0,2,0,0" MaxWidth="540"/>
                                </StackPanel>
                            </CheckBox.Content>
                        </CheckBox>
                        <CheckBox x:Name="OptStreamByDefault"
                                  Margin="0,0,0,4"
                                  Checked="Settings_Changed_Inline"
                                  Unchecked="Settings_Changed_Inline">
                            <CheckBox.Content>
                                <StackPanel>
                                    <TextBlock Text="Stream newly-detected cameras by default" FontSize="14"/>
                                    <TextBlock Text="When a new USB camera is plugged in, automatically start publishing it. Untick if you'd rather opt-in per camera from the tray menu."
                                               Foreground="{StaticResource textMuted}" FontSize="12" TextWrapping="Wrap"
                                               Margin="0,2,0,0" MaxWidth="540"/>
                                </StackPanel>
                            </CheckBox.Content>
                        </CheckBox>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>

        <!-- Status bar. Quiet in the happy path: just a coloured dot next
             to "mediamtx" indicates whether the RTSP server is up. Only
             surfaces a red error message if something goes wrong with the
             supervisor/IPC. -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource bgStatus}"
                BorderBrush="{StaticResource border}" BorderThickness="0,1,0,0"
                Padding="14,7">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- green/red dot -->
                <Ellipse Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#EF4444"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MediaMtxRunning}" Value="True">
                                    <Setter Property="Fill" Value="#10B981"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Foreground="{StaticResource textPrimary}" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="mediamtx: down"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MediaMtxRunning}" Value="True">
                                    <Setter Property="Text" Value="mediamtx: running"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <!-- Error message: visible only when something went wrong. -->
                <TextBlock Text="{Binding ConnectionStatus}" Margin="14,0,0,0"
                           Foreground="#B91C1C" FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Camera grid -->
        <DataGrid x:Name="CamGrid"
                  ItemsSource="{Binding Cameras}"
                  AutoGenerateColumns="False"
                  Background="{StaticResource bgPanel}"
                  Foreground="{StaticResource textPrimary}"
                  RowBackground="{StaticResource bgPanel}"
                  AlternatingRowBackground="{StaticResource bgRowAlt}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource border}"
                  BorderBrush="{StaticResource border}" BorderThickness="0"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  CanUserResizeRows="False" CanUserReorderColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  RowHeight="46"
                  ColumnHeaderHeight="34"
                  SelectionUnit="FullRow"
                  Margin="0">
            <DataGrid.Resources>
                <!-- Header style -->
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"     Value="#F9FAFB"/>
                    <Setter Property="Foreground"     Value="{StaticResource textHeader}"/>
                    <Setter Property="FontWeight"     Value="SemiBold"/>
                    <Setter Property="FontSize"       Value="12"/>
                    <Setter Property="BorderBrush"    Value="{StaticResource border}"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding"        Value="12,8"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </Style>

                <!-- Cell -->
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding"         Value="12,4"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource bgRowSel}"/>
                            <Setter Property="Foreground" Value="{StaticResource textPrimary}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <!-- Row -->
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource bgRowHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource bgRowSel}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- Camera friendly name. Extra left padding so the cam
                     title doesn't sit flush against the row edge. -->
                <DataGridTextColumn Header="Camera" Binding="{Binding Name}" Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8,0,0,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- RTSP path -->
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="92">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace"/>
                            <Setter Property="Foreground" Value="{StaticResource accent}"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Mode dropdown. Friendly display strings ("transcode
                     MJPEG->H.264") map to the supervisor's wire values
                     ("transcode_mjpeg_to_h264"). Only the two transcode
                     modes are exposed; legacy passthrough/raw-to-mjpeg are
                     hidden in the UI and silently coerced on the
                     supervisor side. -->
                <DataGridTemplateColumn Header="Mode" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{x:Static local:Modes.All}"
                                      DisplayMemberPath="Display"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding Mode, Mode=OneWay}"
                                      SelectionChanged="ModeCombo_SelectionChanged"
                                      Tag="{Binding}"
                                      Margin="6,6"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Resolution dropdown. Bound to the per-cam
                     AvailableResolutions (derived from the supervisor's
                     `ffmpeg -list_options` enumeration filtered by the
                     currently-selected Mode), so the user only sees
                     resolutions the cam actually advertises and ffmpeg
                     will accept. If we don't yet have advertised formats
                     (supervisor still enumerating, or older supervisor),
                     ResolutionFallbackConverter substitutes the static
                     Resolutions.All list. -->
                <DataGridTemplateColumn Header="Resolution" Width="115">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding AvailableResolutions, Converter={StaticResource ResolutionFallback}}"
                                      SelectedItem="{Binding Resolution, Mode=OneWay}"
                                      SelectionChanged="ResolutionCombo_SelectionChanged"
                                      Tag="{Binding}"
                                      Margin="6,6"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Status pill: single authoritative state model
                     (matches CameraInfo properties, also drives the tray
                     menu/tooltip): UNPLUGGED, DISABLED, STARTING, ENABLED,
                     STREAMING. The leading dot on STREAMING is the visual
                     cue that a viewer is actually attached right now. -->
                <DataGridTemplateColumn Header="Status" Width="135">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="8,2"
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- Default = UNPLUGGED grey -->
                                        <Setter Property="Background" Value="#F3F4F6"/>
                                        <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <!-- DISABLED: present && !enabled -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Present}" Value="True"/>
                                                    <Condition Binding="{Binding Enabled}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background"  Value="#E5E7EB"/>
                                                <Setter Property="BorderBrush" Value="#9CA3AF"/>
                                            </MultiDataTrigger>
                                            <!-- STARTING: present && enabled && !running -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Present}" Value="True"/>
                                                    <Condition Binding="{Binding Enabled}" Value="True"/>
                                                    <Condition Binding="{Binding Running}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background"  Value="#FEF3C7"/>
                                                <Setter Property="BorderBrush" Value="#F59E0B"/>
                                            </MultiDataTrigger>
                                            <!-- ENABLED: present && enabled && running && no viewers -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Present}" Value="True"/>
                                                    <Condition Binding="{Binding Enabled}" Value="True"/>
                                                    <Condition Binding="{Binding Running}" Value="True"/>
                                                    <Condition Binding="{Binding HasViewers}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background"  Value="#D1FAE5"/>
                                                <Setter Property="BorderBrush" Value="#10B981"/>
                                            </MultiDataTrigger>
                                            <!-- STREAMING: viewer attached -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Present}" Value="True"/>
                                                    <Condition Binding="{Binding Enabled}" Value="True"/>
                                                    <Condition Binding="{Binding Running}" Value="True"/>
                                                    <Condition Binding="{Binding HasViewers}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background"  Value="#DBEAFE"/>
                                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="UNPLUGGED"/>
                                            <Setter Property="Foreground" Value="#6B7280"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Present}" Value="True"/>
                                                        <Condition Binding="{Binding Enabled}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Text"       Value="DISABLED"/>
                                                    <Setter Property="Foreground" Value="#4B5563"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Present}" Value="True"/>
                                                        <Condition Binding="{Binding Enabled}" Value="True"/>
                                                        <Condition Binding="{Binding Running}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Text"       Value="STARTING"/>
                                                    <Setter Property="Foreground" Value="#92400E"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Present}" Value="True"/>
                                                        <Condition Binding="{Binding Enabled}" Value="True"/>
                                                        <Condition Binding="{Binding Running}" Value="True"/>
                                                        <Condition Binding="{Binding HasViewers}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Text"       Value="ENABLED"/>
                                                    <Setter Property="Foreground" Value="#047857"/>
                                                </MultiDataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Present}" Value="True"/>
                                                        <Condition Binding="{Binding Enabled}" Value="True"/>
                                                        <Condition Binding="{Binding Running}" Value="True"/>
                                                        <Condition Binding="{Binding HasViewers}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Text"       Value="● STREAMING"/>
                                                    <Setter Property="Foreground" Value="#1D4ED8"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- PID + Restarts columns intentionally removed in v0.3:
                     not actionable for end users; the supervisor log still
                     carries them for diagnostics. -->

                <!-- Full RTSP URL (selectable + one-click copy) -->
                <DataGridTemplateColumn Header="RTSP URL" Width="*" MinWidth="280">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <DockPanel LastChildFill="True">
                                <Button DockPanel.Dock="Right"
                                        Content="Copy"
                                        Click="CopyUrl_Click"
                                        Tag="{Binding}"
                                        MinWidth="56"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        ToolTip="Copy this RTSP URL to the clipboard"/>
                                <TextBox Text="{Binding FullUrl, Mode=OneWay}"
                                         IsReadOnly="True" BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{StaticResource accent}"
                                         FontFamily="Consolas, Cascadia Mono, monospace"
                                         FontSize="12"
                                         VerticalAlignment="Center"
                                         ToolTip="Click to select; Ctrl+C to copy"/>
                            </DockPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Per-row actions. The activate/deactivate button binds
                     to set-stream-enabled; its label flips based on the
                     Enabled flag so a single button covers both directions.
                     (A Restart button used to live here; it was rarely
                     useful in practice. set-mode/set-stream-enabled
                     already restart the publisher. The Restart_Click
                     handler is kept dormant so we can wire it back if
                     somebody asks.) -->
                <DataGridTemplateColumn Header="" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Click="EnableToggle_Click" Tag="{Binding}" MinWidth="92"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Content" Value="Deactivate"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                <Setter Property="Content" Value="Activate"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
