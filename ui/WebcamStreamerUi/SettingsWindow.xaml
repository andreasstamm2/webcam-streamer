<Window x:Class="WebcamStreamerUi.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Webcam Streamer — Settings"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="#1F2937">
    <!--
        Standalone settings dialog. Three toggles per the locked design:
          - Notifications (mirrors tray menu's Notifications)
          - Start on Windows logon (HKCU\...\Run)
          - Stream newly-detected cameras by default (settings.json,
            consumed by supervisor on hot-plug)
        Live-applies on click; no Save button. Tray menu's Notifications
        toggle and this one stay in sync via App.Instance.Settings.
    -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontSize="18" FontWeight="SemiBold"
                   Margin="0,0,0,14"/>

        <CheckBox x:Name="NotificationsBox" Grid.Row="1" Margin="0,0,0,8"
                  Checked="Settings_Changed" Unchecked="Settings_Changed">
            <CheckBox.Content>
                <StackPanel>
                    <TextBlock Text="Show notifications" FontSize="14"/>
                    <TextBlock Text="Pop a tray toast when a viewer connects, or when an authentication attempt fails."
                               Foreground="#6B7280" FontSize="12" TextWrapping="Wrap"
                               Margin="0,2,0,0" MaxWidth="380"/>
                </StackPanel>
            </CheckBox.Content>
        </CheckBox>

        <CheckBox x:Name="AutostartBox" Grid.Row="2" Margin="0,0,0,8"
                  Checked="Settings_Changed" Unchecked="Settings_Changed">
            <CheckBox.Content>
                <StackPanel>
                    <TextBlock Text="Start automatically when I log in" FontSize="14"/>
                    <TextBlock Text="Adds a per-user registry entry (HKCU\...\Run). Streaming starts shortly after you sign in to Windows."
                               Foreground="#6B7280" FontSize="12" TextWrapping="Wrap"
                               Margin="0,2,0,0" MaxWidth="380"/>
                </StackPanel>
            </CheckBox.Content>
        </CheckBox>

        <CheckBox x:Name="DefaultEnabledBox" Grid.Row="3" Margin="0,0,0,12"
                  Checked="Settings_Changed" Unchecked="Settings_Changed">
            <CheckBox.Content>
                <StackPanel>
                    <TextBlock Text="Stream newly-detected cameras by default" FontSize="14"/>
                    <TextBlock Text="When a new USB camera is plugged in, automatically start publishing it. Untick if you'd rather opt-in per camera from the tray menu."
                               Foreground="#6B7280" FontSize="12" TextWrapping="Wrap"
                               Margin="0,2,0,0" MaxWidth="380"/>
                </StackPanel>
            </CheckBox.Content>
        </CheckBox>

        <Border Grid.Row="4" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                CornerRadius="4" Padding="10" Margin="0,0,0,12"
                Visibility="{Binding StatusVisibility}">
            <TextBlock x:Name="StatusText" Text="" Foreground="#1D4ED8" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" MinWidth="80" Padding="14,6" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
