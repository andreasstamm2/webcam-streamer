<Window x:Class="WebcamStreamerUi.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Webcam Streamer"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F5F7FA"
        FontFamily="Segoe UI" FontSize="13"
        Foreground="#1F2937"
        Icon="/app.ico">
    <!--
        Read-only "About" dialog. Reached from:
          - Tray menu → "About..."
          - MainWindow toolbar → "About" button

        Version text is populated from the assembly's InformationalVersion
        attribute (set via <Version> in the csproj) in code-behind. All
        hyperlinks open in the default browser / mail client via
        Process.Start with UseShellExecute=true.

        Window.Icon supplies the chrome icon (top-left + taskbar). The
        large in-content icon below uses the same .ico via the pack URI
        registered in the csproj.
    -->
    <Grid Margin="22,18,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: icon + product name + version, in a single horizontal block -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <!-- Use the dedicated 256x256 PNG (embedded as app-256.png)
                 so WPF scales the largest source down to the 64px slot
                 instead of pulling a smaller frame out of the .ico and
                 scaling it up. -->
            <Image Width="64" Height="64" Source="/app-256.png"
                   VerticalAlignment="Top"/>

            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Webcam Streamer"
                           FontSize="20" FontWeight="SemiBold"/>
                <TextBlock x:Name="VersionText"
                           Text="Version —"
                           Foreground="#6B7280" FontSize="13"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Row 1: License -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="License"
                       Foreground="#6B7280" FontSize="11"
                       FontWeight="SemiBold"
                       Margin="0,0,0,2"/>
            <TextBlock>
                <Hyperlink NavigateUri="https://www.gnu.org/licenses/gpl-3.0.html"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    GNU General Public License v3.0
                </Hyperlink>
                <Run Text="  —  see "/>
                <Hyperlink x:Name="LicenseFileLink"
                           NavigateUri="https://github.com/andreasstamm2/webcam-streamer/blob/main/LICENSE"
                           RequestNavigate="Hyperlink_RequestNavigate">LICENSE</Hyperlink>
                <Run Text="."/>
            </TextBlock>
        </StackPanel>

        <!-- Row 2: Developer -->
        <StackPanel Grid.Row="2" Margin="0,8,0,8">
            <TextBlock Text="Developer"
                       Foreground="#6B7280" FontSize="11"
                       FontWeight="SemiBold"
                       Margin="0,0,0,2"/>
            <TextBlock>
                <Run Text="Andreas Stamm"/>
                <Run Text="  —  "/>
                <Hyperlink NavigateUri="mailto:andreasstamm@gmx.de"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    andreasstamm@gmx.de
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <!-- Row 3: Project -->
        <StackPanel Grid.Row="3" Margin="0,8,0,16">
            <TextBlock Text="Project"
                       Foreground="#6B7280" FontSize="11"
                       FontWeight="SemiBold"
                       Margin="0,0,0,2"/>
            <TextBlock>
                <Hyperlink NavigateUri="https://github.com/andreasstamm2/webcam-streamer"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    github.com/andreasstamm2/webcam-streamer
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <!-- Row 4: Close button -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" MinWidth="80" Padding="14,6"
                    IsDefault="True" IsCancel="True"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
